{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omnihive.dev/schemas/task.schema.json",
  "title": "Task",
  "description": "A unit of work submitted to the Omnihive execution control plane.",
  "type": "object",
  "required": ["task_id", "goal", "status", "trace_id", "created_at", "updated_at"],
  "properties": {
    "task_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this task."
    },
    "goal": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable goal description."
    },
    "inputs": {
      "type": "object",
      "description": "Arbitrary key-value inputs for the task.",
      "additionalProperties": true
    },
    "budget": {
      "type": "number",
      "minimum": 0,
      "description": "Maximum spend in USD for this task."
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 50,
      "description": "Priority (0=lowest, 100=highest)."
    },
    "status": {
      "type": "string",
      "enum": ["CREATED", "PLANNING", "RUNNING", "SUCCESS", "FAILED", "CANCELLED"],
      "description": "Current state of the task."
    },
    "trace_id": {
      "type": "string",
      "format": "uuid",
      "description": "Correlation ID for tracing across steps."
    },
    "project_dir": {
      "type": "string",
      "description": "Path to the project directory."
    },
    "agent_roles": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered list of agent roles participating."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "error": {
      "type": ["string", "null"],
      "description": "Error message if status is FAILED."
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "task_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "goal": "Build landing page for SaaS product",
      "inputs": { "seed_prompt": "AI-powered analytics dashboard" },
      "budget": 5.0,
      "priority": 70,
      "status": "RUNNING",
      "trace_id": "f0e1d2c3-b4a5-6789-0fed-cba987654321",
      "project_dir": "/projects/my-saas",
      "agent_roles": ["ceo", "fullstack", "devops", "critic"],
      "created_at": "2025-06-01T10:00:00Z",
      "updated_at": "2025-06-01T10:05:00Z",
      "completed_at": null,
      "error": null
    },
    {
      "task_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
      "goal": "Weekly strategic review",
      "inputs": {},
      "budget": 2.0,
      "priority": 50,
      "status": "SUCCESS",
      "trace_id": "e1d2c3b4-a5f6-7890-fedc-ba9876543210",
      "project_dir": "/projects/review",
      "agent_roles": ["research", "cfo", "ceo"],
      "created_at": "2025-06-01T08:00:00Z",
      "updated_at": "2025-06-01T08:30:00Z",
      "completed_at": "2025-06-01T08:30:00Z",
      "error": null
    }
  ]
}
